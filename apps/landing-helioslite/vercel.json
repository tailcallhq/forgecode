{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/docs",              "destination": "/docs/index.html" },
    { "source": "/docs/quickstart",   "destination": "/docs/quickstart.html" },
    { "source": "/docs/updates",      "destination": "/docs/updates.html" },
    { "source": "/docs/FORK.md",      "destination": "/docs/FORK.html" },
    { "source": "/docs/NOTICE.md",    "destination": "/docs/NOTICE.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
